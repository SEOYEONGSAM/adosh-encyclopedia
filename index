가", "v": "진입별/일시별", "ref": "3.6(a), 3.6(b)"}, {"l": "구조계획", "v": "진입 전 준비", "ref": "3.8(a)"}, {"l": "통신", "v": "본질안전/자주 시험", "ref": "3.9(c)"}]}], "28.0": [{"h": "Hot Work Permit", "rows": [{"l": "지정구역 밖", "v": "Permit 필수", "ref": "3.2(a)"}, {"l": "가연물 제거", "v": "10m 이내", "ref": "3.3.5(a)(ii)"}, {"l": "화재감시", "v": "작업 중 + 1시간", "ref": "3.3.5(a)(vii)"}, {"l": "위험구역 LEL", "v": "5% 미만", "ref": "3.4(a)(ix)"}, {"l": "장비점검", "v": "매일 유능한 자", "ref": "3.1.1(b)(iv)"}]}, {"h": "Gas/Welding", "rows": [{"l": "산소-연료가스", "v": "6m 이상 분리", "ref": "3.7.1(a)(iv)"}, {"l": "아세틸렌 수평", "v": "15분 세운 뒤 사용", "ref": "3.7.2(a)(ix)"}, {"l": "Flashback", "v": "모든 산소-아세틸렌 장비", "ref": "3.6(a)(vi)"}, {"l": "기능시험", "v": "6개월마다", "ref": "3.8(a)(ii)"}, {"l": "교체/개보수", "v": "5년마다", "ref": "3.8(a)(ii)"}]}]};
const ACCENTS = ["#2dd4bf","#f5b74e","#7dd3fc","#c4b5fd","#f0a3c0","#a3e635","#fca5a5","#5eead4"];

let view="home", cur=-1, lang="both", keyOnly=false, query="";
const el=id=>document.getElementById(id);
const total=c=>c.sections.reduce((a,s)=>a+s.items.length,0);
const keys=c=>c.sections.reduce((a,s)=>a+s.items.filter(i=>i.key).length,0);
const docKind=c=>c.kind||"CoP";
const docKey=c=>c.docId||c.code;

el("foot").innerHTML="ADOSH-SF Reference Library — PUBLIC.<br>한국어는 참조용 번역이며, 법적 효력은 영문 원문이 우선합니다.";

const copyIcon='<svg viewBox="0 0 24 24"><rect x="9" y="9" width="12" height="12" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg>';
function esc(s){return s.replace(/[&<>]/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;"}[c]))}
function hl(s){ if(!query) return esc(s);
  const re=new RegExp("("+query.replace(/[.*+?^${}()|[\]\\]/g,"\\$&")+")","ig");
  return esc(s).replace(re,'<mark style="background:#3a4a2a;color:#e9f5d0;padding:0 1px;border-radius:2px">$1</mark>');}
function match(it){ if(keyOnly&&!it.key)return false; if(!query)return true;
  const q=query.toLowerCase();
  return it.id.toLowerCase().includes(q)||it.en.toLowerCase().includes(q)||it.ko.toLowerCase().includes(q);}
function cardHtml(it){
  const en=(lang!=="ko")?`<div class="en">${hl(it.en)}</div>`:"";
  const ko=(lang!=="en")?`<div class="ko">${hl(it.ko)}</div>`:"";
  return `<div class="card${it.key?' key':''}"><span class="cid">${hl(it.id)}</span>`+
    `${it.key?'<span class="keybadge">● KEY</span>':''}`+
    `<button class="copy" data-copy="${encodeURIComponent(it.id+'\n'+it.ko+'\n'+it.en)}">${copyIcon}</button>`+
    en+ko+`</div>`;}

function render(){
  el("content").innerHTML="";el("home").innerHTML="";
  el("empty").classList.add("hide");
  if(view==="home") renderHome(); else renderCop();
}

function renderHome(){
  el("back").classList.remove("show");
  el("chips").classList.add("hide");
  el("quick").classList.add("hide");
  el("title").innerHTML='<span class="doc">ADOSH</span> 기준 백과사전';
  el("ver").textContent=LIB.cops.length+" 문서";
  el("q").placeholder="전체 ADOSH 기준 검색 — 조항·키워드";

  if(!query && !keyOnly){
    el("count").textContent="";
    el("home").innerHTML=`<div class="lead">현장에서 참조할 ADOSH 기준 문서를 선택하세요. CoP와 Mechanism을 함께 검색할 수 있습니다.</div>`+
      `<div class="grid">`+LIB.cops.map((c,i)=>
      `<button class="copcard" data-cop="${i}" style="--accent:${ACCENTS[i%ACCENTS.length]}">`+
      `<span class="code">${docKind(c)} ${c.code}</span><span class="title">${c.title}</span>`+
      `<span class="titleko">${c.titleKo}</span>`+
      `<span class="meta">${total(c)} 조항 · KEY ${keys(c)}</span></button>`).join("")+`</div>`;
    return;
  }
  // cross-CoP search results
  let shown=0,html="";
  LIB.cops.forEach((c,i)=>{
    const groups=c.sections.map(s=>({s,items:s.items.filter(match)})).filter(g=>g.items.length);
    const n=groups.reduce((a,g)=>a+g.items.length,0);
    if(!n)return; shown+=n;
    html+=`<div class="resulthead" data-cop="${i}" style="color:${ACCENTS[i%ACCENTS.length]}">`+
      `${docKind(c)} ${c.code} · ${c.title} <span class="cnt">(${n})</span><span class="open">열기 →</span></div>`;
    groups.forEach(g=>{g.items.forEach(it=>html+=cardHtml(it))});
  });
  el("count").textContent=`${shown} 조항 · ${LIB.cops.length}개 문서 검색`;
  el("content").innerHTML=html;
  el("empty").classList.toggle("hide",shown>0);
}

function renderCop(){
  const c=LIB.cops[cur];
  el("back").classList.add("show");
  el("title").innerHTML=`<span class="doc">${docKind(c)} ${c.code}</span> ${c.title}`;
  el("ver").textContent="v"+c.version;
  el("q").placeholder=`${docKind(c)} ${c.code} 내 검색`;

  // chips
  el("chips").classList.remove("hide");
  el("chips").innerHTML=c.sections.map(s=>`<a class="chip" href="#s${s.sec.replace(/\./g,'-')}">${s.sec}</a>`).join("");

  // quick ref
  const qr=QUICKREFS[docKey(c)];
  if(qr){ el("quick").classList.remove("hide");
    el("qgrid").innerHTML=qr.map(g=>`<div class="qgroup"><h4>${g.h}</h4>${
      g.rows.map(r=>`<div class="qrow"><span class="l">${r.l}<span class="ref">${r.ref}</span></span><span class="v">${r.v}</span></div>`).join("")}</div>`).join("");
  } else el("quick").classList.add("hide");

  let shown=0,html="";
  for(const s of c.sections){
    const items=s.items.filter(match); if(!items.length)continue; shown+=items.length;
    html+=`<section class="grp" id="s${s.sec.replace(/\./g,'-')}"><div class="ghead">`+
      `<span class="num">${s.sec}</span><span class="t">${s.title}</span><span class="tko">${s.titleKo}</span></div>`;
    items.forEach(it=>html+=cardHtml(it));
    html+=`</section>`;
  }
  el("content").innerHTML=html;
  el("empty").classList.toggle("hide",shown>0);
  el("count").textContent=(query||keyOnly)?`${shown} / ${total(c)} 조항 표시`:`전체 ${total(c)} 조항 · ${c.sections.length}개 섹션`;
}

function openCop(i){view="cop";cur=i;window.scrollTo(0,0);render();}
function goHome(){view="home";cur=-1;render();}

el("back").addEventListener("click",goHome);
el("q").addEventListener("input",e=>{query=e.target.value.trim();render()});
el("lang").addEventListener("click",e=>{const b=e.target.closest("button");if(!b)return;
  lang=b.dataset.l;[...el("lang").children].forEach(x=>x.classList.toggle("on",x===b));render()});
el("keytog").addEventListener("click",()=>{keyOnly=!keyOnly;el("keytog").classList.toggle("on",keyOnly);render()});
document.body.addEventListener("click",e=>{
  const cp=e.target.closest("[data-cop]"); if(cp){openCop(+cp.dataset.cop);return;}
  const b=e.target.closest(".copy"); if(b){e.stopPropagation();
    navigator.clipboard.writeText(decodeURIComponent(b.dataset.copy)).then(()=>{
      b.classList.add("done");setTimeout(()=>b.classList.remove("done"),1200)});}
});

render();

// PWA
try{
  const mani={name:"ADOSH 기준 백과사전",short_name:"ADOSH",display:"standalone",
    background_color:"#0d1522",theme_color:"#0d1522",start_url:".",
    icons:[{src:"data:image/svg+xml,"+encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 192 192"><rect width="192" height="192" rx="34" fill="#0d1522"/><text x="96" y="128" font-size="72" text-anchor="middle" fill="#2dd4bf" font-family="sans-serif" font-weight="700">ADOSH</text></svg>'),sizes:"192x192",type:"image/svg+xml"}]};
  const link=document.createElement("link");link.rel="manifest";
  link.href=URL.createObjectURL(new Blob([JSON.stringify(mani)],{type:"application/manifest+json"}));
  document.head.appendChild(link);
  if(("serviceWorker" in navigator)&&location.protocol.startsWith("http")){
    const sw=`self.addEventListener("install",e=>self.skipWaiting());
      self.addEventListener("activate",e=>e.waitUntil(self.clients.claim()));
      self.addEventListener("fetch",e=>{e.respondWith(caches.open("adosh-v1").then(c=>c.match(e.request).then(r=>r||fetch(e.request).then(res=>{if(e.request.method==="GET"&&res.ok)c.put(e.request,res.clone());return res;}).catch(()=>caches.match(location.pathname)))));});`;
    navigator.serviceWorker.register(URL.createObjectURL(new Blob([sw],{type:"text/javascript"}))).catch(()=>{});
  }
}catch(e){}
</script>
</body>
